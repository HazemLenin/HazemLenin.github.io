---
import { profile } from "../data/profile";
import SectionHeading from "./SectionHeading.astro";
---

<section class="reveal mx-auto max-w-4xl px-6 py-16">
  <SectionHeading id="education" title="Education & Certifications" />
  <div class="max-w-2xl space-y-6">
    <div>
      <h3 class="font-display text-lg tracking-tight">
        {profile.education.degree}
      </h3>
      <p class="mt-1 text-sm text-soft">
        {profile.education.school} · {profile.education.year} · {profile.education.grade}
      </p>
    </div>
    <ul class="space-y-2 text-sm text-soft">
      {
        profile.certifications.map((cert) => (
          <li>
            <span class="text-ink">{cert.name}</span> — {cert.issuer}
          </li>
        ))
      }
    </ul>
  </div>
</section>
