---
import { Menu, Moon, Sun, X } from "@lucide/astro";
import { profile } from "../data/profile";

const links = [
  { href: "#about", label: "About" },
  { href: "#experience", label: "Experience" },
  { href: "#projects", label: "Projects" },
  { href: "#skills", label: "Skills" },
  { href: "#education", label: "Education" },
  { href: "#contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-line bg-paper/80 backdrop-blur">
  <nav class="relative mx-auto flex max-w-4xl items-center justify-between px-6 py-4">
    <a href="#top" class="font-display text-lg tracking-tight">
      {profile.name}
    </a>
    <div class="flex items-center gap-5">
      <ul class="hidden items-center gap-5 text-sm text-soft sm:flex">
        {
          links.map((link) => (
            <li>
              <a href={link.href} class="transition-colors hover:text-ink">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
      <details class="group relative sm:hidden">
        <summary
          aria-label="Open navigation menu"
          class="flex cursor-pointer list-none items-center text-soft transition-colors marker:content-[''] hover:text-ink [&::-webkit-details-marker]:hidden"
        >
          <Menu
            class="size-5 group-open:hidden"
            stroke-width={1.5}
            aria-hidden="true"
          />
          <X
            class="hidden size-5 group-open:block"
            stroke-width={1.5}
            aria-hidden="true"
          />
        </summary>
        <ul class="absolute top-full right-0 mt-3 w-48 divide-y divide-line border border-line bg-paper py-2 text-sm text-soft shadow-none">
          {
            links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="block px-4 py-2 transition-colors hover:text-ink"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </details>
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle theme"
        class="cursor-pointer text-soft transition-colors hover:text-ink"
      >
        <Sun
          class="hidden size-5 dark:block"
          stroke-width={1.5}
          aria-hidden="true"
        />
        <Moon
          class="size-5 dark:hidden"
          stroke-width={1.5}
          aria-hidden="true"
        />
      </button>
    </div>
  </nav>
</header>

<script>
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const dark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", dark ? "dark" : "light");
  });

  const menu = document.querySelector<HTMLDetailsElement>("nav details");
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.open = false;
    });
  });
</script>
