---
import { profile } from "../data/profile";
import SectionHeading from "./SectionHeading.astro";
---

<section class="reveal mx-auto max-w-4xl px-6 py-16">
  <SectionHeading id="projects" title="Projects" />
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      profile.projects.map((project) => (
        <article class="flex flex-col rounded-lg border border-line bg-raised p-6 transition-colors hover:border-accent">
          <div class="flex items-baseline justify-between gap-3">
            <h3 class="font-display text-lg tracking-tight">
              {project.link ? (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener"
                  class="transition-colors hover:text-accent"
                >
                  {project.name}
                  <span aria-hidden="true"> ↗</span>
                </a>
              ) : (
                project.name
              )}
            </h3>
            {project.note && (
              <span class="shrink-0 text-xs tracking-wide text-soft uppercase">
                {project.note}
              </span>
            )}
          </div>
          <p class="mt-3 grow text-sm leading-relaxed text-soft">
            {project.description}
          </p>
          <ul class="mt-5 flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <li class="rounded-full border border-line px-2.5 py-0.5 text-xs text-soft">
                {tag}
              </li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</section>
